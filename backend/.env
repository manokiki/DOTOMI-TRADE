# ── Base de données ───────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./dotomi_trade.db
# Prod Railway : postgresql+asyncpg://user:password@host/dbname

# ── Données de marché ─────────────────────────────────────────────────────────
BINANCE_BASE_URL=https://api.binance.com
DEFAULT_SYMBOL=BTCUSDT
DEFAULT_TIMEFRAME=1h
SYMBOLS_TO_SCAN=BTCUSDT,ETHUSDT,SOLUSDT

# ── APIs (tu as ces 3 clés) ───────────────────────────────────────────────────
TWELVEDATA_API_KEY=d3ec27950ac8493dbf398419c4cf0661
FRED_API_KEY=9729bf59896a015c65f277fd20bfe156

# ── Bybit (tu as la clé — lecture seule uniquement) ───────────────────────────
# Pas encore utilisée directement dans l'API actuelle
# Le funding rate Bybit est appelé via endpoint public sans clé
# Garde-la pour plus tard si tu veux ajouter le broker sync

# ── APIs non requises (remplacées par solutions gratuites) ────────────────────
# CryptoPanic → remplacé par RSS feeds (feedparser)
# CoinGlass   → remplacé par Binance Futures public
CRYPTOPANIC_API_KEY=
COINGLASS_API_KEY=

# ── Risk Management CDC — ne pas modifier ─────────────────────────────────────
DEFAULT_CAPITAL=100.0
RISK_PCT_PER_TRADE=1.0
MAX_DAILY_LOSS_PCT=3.0
MAX_WEEKLY_LOSS_PCT=6.0
MAX_DRAWDOWN_ABSOLUTE_PCT=15.0
MAX_TRADES_PER_DAY=3
MIN_RRR=2.5
THRESHOLD_AUTHORIZED=85.0

# ── Kill Zones UTC exactes ────────────────────────────────────────────────────
LONDON_KZ_START=7
LONDON_KZ_END=10
NEWYORK_KZ_START=12
NEWYORK_KZ_END=15
NY_CLOSE_START=17
NY_CLOSE_END=19

# ── Alerting email (optionnel) ────────────────────────────────────────────────
ALERTS_ENABLED=false
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_TO=

# ── Scheduler ─────────────────────────────────────────────────────────────────
SCHEDULER_ENABLED=false

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
